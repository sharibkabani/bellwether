# Copy to .env and fill in. Never commit .env.

# --- AI signal (only the key for your chosen llm.provider is needed) ---
# Default provider is Groq (free, best quality): get a free key at
# console.groq.com (no credit card) — it runs openai/gpt-oss-120b.
GROQ_API_KEY=
# Alternatives if you switch llm.provider:
#   ollama  -> no key (local; `ollama pull qwen3:8b`)
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Live Kraken trading (only needed for `--live` real orders) ---
# Create an API key in Kraken → Settings → API with "Query Funds" and
# "Create & Modify Orders" permissions. Paper mode and market data need neither.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Email digest (channel: email) ---
# For Gmail, use an App Password, not your account password.
SMTP_PASSWORD=

# --- SMS digest (channel: sms, via Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
