# Copy to .env and fill in. Never commit .env.

# --- AI signal (free LLM providers; the bot fails over best-first) ---
# Set keys for the providers listed in config.yaml `llm.providers`; any
# provider without a key is skipped. All free, no credit card:
#   Groq     (console.groq.com)      — fastest gpt-oss-120b, ~1k req/day in 2026
#   Cerebras (cloud.cerebras.ai)     — 1M tokens/day, same gpt-oss-120b
#   OpenRouter (openrouter.ai)       — free ":free" model variants
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
# Optional: Gemini free tier needs a linked billing account in AI Studio.
# GEMINI_API_KEY=
# Local, no key, no limits (needs a box with several GB RAM): llm.provider: ollama
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Live Kraken trading (only needed for `--live` real orders) ---
# Create an API key in Kraken → Settings → API with "Query Funds" and
# "Create & Modify Orders" permissions. Paper mode and market data need neither.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Email digest (channel: email) ---
# For Gmail, use an App Password, not your account password.
SMTP_PASSWORD=

# --- SMS digest (channel: sms, via Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
